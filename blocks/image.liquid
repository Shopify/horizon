{% liquid
  assign block_settings = block.settings
  assign ratio = 1

  case block_settings.image_ratio
    when 'landscape'
      assign ratio = '16 / 9'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'adapt'
      assign ratio = block_settings.image.aspect_ratio
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif

  assign has_hover_image = false
  if block_settings.image != blank and block_settings.image_on_hover != blank
    assign has_hover_image = true
  endif

  assign has_image_border = false
  if block_settings.border != 'none'
    assign has_image_border = true
  endif
%}

{% capture class %}
  image-block image-block--{{ block.id }} image-block--height-{{ block_settings.height }}{% if has_hover_image %} image-block--has-hover-image{% endif %}{% if has_image_border %} image-block--bordered{% endif %} spacing-style size-style
{% endcapture %}

{% capture style %}
  --ratio: {{ ratio }};
  {% render 'size-style', settings: block_settings %}
  {% render 'spacing-style', settings: block_settings %}
{% endcapture %}

{% capture image_frame_style %}
  {% if has_image_border %}
    {% render 'border-override', settings: block_settings %}
    --image-block-inner-padding: {{ block_settings.image_border_padding }}px;
  {% endif %}
{% endcapture %}

{% capture image_border_style %}
  --ratio: {{ ratio }};
{% endcapture %}

{% liquid
  assign media_width_desktop = '100vw'
  assign media_width_mobile = '100vw'
  assign sizes = 'auto, (min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '240, 352, 832, 1200, 1600, 1920, 2560, 3840'
  assign image_alt = block_settings.image.alt | default: block_settings.image_on_hover.alt | default: ''
%}

{% capture image %}
  <div
    class="image-block__frame{% if has_image_border %} image-block__frame--bordered border-style{% endif %}"
    style="{{ image_frame_style }}"
  >
    <div class="image-block__media{% if has_hover_image %} image-block__media--has-hover{% endif %}">
    {%- if block_settings.image -%}
      {{
        block_settings.image
        | image_url: width: 3840
        | image_tag:
          width: block_settings.image.width,
          widths: widths,
          height: block_settings.image.height,
          class: 'image-block__image image-block__image--primary',
          style: image_border_style,
          sizes: sizes,
          alt: image_alt
      }}
      {%- if has_hover_image -%}
        {{
          block_settings.image_on_hover
          | image_url: width: 3840
          | image_tag:
            width: block_settings.image_on_hover.width,
            widths: widths,
            height: block_settings.image_on_hover.height,
            class: 'image-block__image image-block__image--hover',
            style: image_border_style,
            sizes: sizes,
            alt: ''
        }}
      {%- endif -%}
    {%- else -%}
      <div class="placeholder-image size-style" style="{{ image_border_style }}">
        {{ 'detailed-apparel-1' | placeholder_svg_tag: 'hero__media' }}
      </div>
    {%- endif -%}
    </div>
  </div>
{% endcapture %}

{% if block_settings.link == blank %}
  <div
    class="{{ class }}"
    style="{{ style }}"
    {% if has_hover_image %}
      tabindex="0"
    {% endif %}
    {{ block.shopify_attributes }}
  >
    {{ image }}
  </div>
{% else %}
  <a
    href="{{ block_settings.link }}"
    class="{{ class }}"
    style="{{ style }}"
    {{ block.shopify_attributes }}
  >
    {{ image }}
  </a>
{% endif %}

{% stylesheet %}
  .placeholder-image {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
  }

  .image-block {
    display: flex;

    /* When the image is nested in a group, section, etc, respect the parent's horizontal alignment */
    justify-content: var(--horizontal-alignment, 'inline-start');
  }

  .image-block--height-fill .image-block__frame,
  .image-block--height-fill .image-block__media {
    height: 100%;
  }

  .image-block--height-fill .image-block__image {
    height: 100%;
  }

  .image-block__frame {
    width: 100%;
    max-width: 100%;
  }

  .image-block__frame--bordered {
    box-sizing: border-box;
    padding: var(--image-block-inner-padding, 0);
    overflow: hidden;
    --image-block-inner-radius: max(0px, calc(var(--border-radius, 0px) - var(--image-block-inner-padding, 0px)));
  }

  .image-block__media {
    position: relative;
    width: 100%;
    max-width: 100%;
  }

  .image-block--bordered .image-block__media,
  .image-block--bordered .image-block__media--has-hover {
    border-radius: var(--image-block-inner-radius, 0);
    overflow: hidden;
  }

  .image-block__media--has-hover {
    --image-block-hover-duration: 0.5s;
    --image-block-hover-easing: ease;
    --image-block-hover-zoom: var(--hover-subtle-zoom-amount, 1.015);
    --image-block-hover-zoom-duration: 0.65s;

    overflow: hidden;
    border-radius: 16px;
  }

  .image-block--bordered .image-block__media--has-hover {
    border-radius: var(--image-block-inner-radius, 16px);
  }

  .image-block__image {
    object-fit: cover;
    aspect-ratio: var(--ratio);
    border-radius: 16px;
    display: block;
    width: 100%;
    height: auto;
  }

  .image-block--bordered .image-block__image,
  .image-block--bordered .placeholder-image {
    border-radius: var(--image-block-inner-radius, 0);
  }

  .image-block__media--has-hover .image-block__image--primary {
    position: relative;
    z-index: 0;
    transition: opacity var(--image-block-hover-duration) var(--image-block-hover-easing);
  }

  .image-block__image--hover {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1);
    transition:
      opacity var(--image-block-hover-duration) var(--image-block-hover-easing),
      transform var(--image-block-hover-zoom-duration) var(--ease-out-quad);
  }

  @media (prefers-reduced-motion: reduce) {
    .image-block__media--has-hover .image-block__image--primary,
    .image-block__image--hover {
      transition: none;
    }

    .image-block__image--hover {
      transform: none;
    }
  }

  @media (hover: hover) {
    .image-block--has-hover-image:hover .image-block__image--hover,
    .image-block--has-hover-image:focus-within .image-block__image--hover,
    .image-block__media--has-hover:hover .image-block__image--hover {
      opacity: 1;
    }

    .image-block--has-hover-image:hover .image-block__image--primary,
    .image-block--has-hover-image:focus-within .image-block__image--primary,
    .image-block__media--has-hover:hover .image-block__image--primary {
      opacity: 0;
    }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .image-block--has-hover-image:hover .image-block__image--hover,
    .image-block--has-hover-image:focus-within .image-block__image--hover,
    .image-block__media--has-hover:hover .image-block__image--hover {
      transform: scale(var(--image-block-hover-zoom));
    }
  }

  .image-block:has(.image-block__image--hover):focus-visible {
    outline: 2px solid rgb(var(--color-foreground-rgb));
    outline-offset: 4px;
    border-radius: 16px;
  }

  .image-block--bordered:has(.image-block__image--hover):focus-visible {
    border-radius: var(--border-radius, 0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.image",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "image_picker",
      "id": "image_on_hover",
      "label": "Image on hover",
      "info": "Shown when the pointer hovers over the image. Requires a main image."
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "image_border_padding",
      "label": "t:settings.image_border_padding",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.aspect_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:settings.height",
      "options": [
        {
          "value": "fit",
          "label": "t:options.fit_content"
        },
        {
          "value": "fill",
          "label": "t:options.fill"
        }
      ],
      "default": "fit",
      "visible_if": "{{ block.settings.image_ratio == 'adapt' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.image",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
