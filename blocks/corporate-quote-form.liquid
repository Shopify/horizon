      "default": "Esdeveniments i càtering\nRegals d'empresa\nSubscripció / wholesale\nTeam building"
    },
    {
      "type": "text",
      "id": "label_company",
      "label": "Company label",
      "default": "Empresa"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "Phone label",
      "default": "Teléfono (opcional)"
    },
    {
      "type": "text",
      "id": "label_volume",
      "label": "Date / volume label",
      "default": "Fecha / volumen"
    },
    {
      "type": "text",
      "id": "volume_placeholder",
      "label": "Date / volume placeholder",
      "default": "p.ej. 150 uds, 12 dic"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit label",
      "default": "Demanar pressupost"
    },
    {
      "type": "text",
      "id": "response_note",
      "label": "Response note",
      "default": "Respuesta en 24h laborables"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "Hem rebut la teva sol·licitud. Respuesta en 24h laborables."
    }
  ],
  "presets": [
    {
      "name": "B2B quote form",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}
