  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Formulari de pressupost"
    },
    {
      "type": "text",
      "id": "label_service",
      "label": "Service label",
      "default": "Què necessites?"
    },
    {
      "type": "text",
      "id": "select_placeholder",
      "label": "Select placeholder",
      "default": "Selecciona…"
    },
    {
