{% liquid
  assign has_background_image = false
  if section.settings.background_image != blank
    assign has_background_image = true
  endif
  assign column_count = section.blocks.size
  if column_count < 1
    assign column_count = 1
  endif
%}

<section
  class="column-callouts section section--full-width color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --column-callouts-min-height: {{ section.settings.section_height }};
    --column-callouts-overlay-max-width: {{ section.settings.content_width | plus: 80 }}px;
    --column-callouts-columns: {{ column_count }};
  "
  data-testid="column-callouts"
>
  <div class="column-callouts__backgrounds" aria-hidden="true">
    {% if has_background_image %}
      {{
        section.settings.background_image
        | image_url: width: 3840
        | image_tag:
          widths: '750, 1100, 1500, 2000, 2500, 3000, 3840',
          sizes: '100vw',
          class: 'column-callouts__background-image column-callouts__background-image--default',
          alt: ''
      }}
    {% else %}
      <div class="column-callouts__background-placeholder column-callouts__background-image--default"></div>
    {% endif %}

    {% for block in section.blocks %}
      {% if block.settings.background_image != blank %}
        <div
          class="column-callouts__background-image column-callouts__background-image--hover column-callouts__background-image--{{ block.id }}"
          style="background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');"
        ></div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="column-callouts__overlay">
    {% if section.settings.heading != blank %}
      <h2 class="column-callouts__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="column-callouts__grid" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign icon_color_index = forloop.index0 | modulo: 3 | plus: 1
        %}
        <article
          class="column-callouts__item column-callouts__item--icon-color-{{ icon_color_index }}"
          role="listitem"
          data-callout-id="{{ block.id }}"
          {% if block.settings.background_image != blank %}
            tabindex="0"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          {% if block.settings.icon != blank %}
            <div class="column-callouts__icon" aria-hidden="true">
              {{ block.settings.icon }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="column-callouts__item-heading">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="column-callouts__item-text rte">
              {{ block.settings.text }}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  {% for block in section.blocks %}
    {% if block.settings.background_image != blank %}
      @media (hover: hover) {
        .column-callouts:has([data-callout-id="{{ block.id }}"]:hover) .column-callouts__background-image--{{ block.id }},
        .column-callouts:has([data-callout-id="{{ block.id }}"]:focus-within) .column-callouts__background-image--{{ block.id }} {
          opacity: 1;
        }
      }
    {% endif %}
  {% endfor %}
{% endstyle %}

{% stylesheet %}
  .column-callouts {
    --column-callouts-hover-duration: 0.45s;
    --column-callouts-hover-easing: ease;
    --column-callouts-text-lift: -0.65rem;
    --column-callouts-icon-color-1: #f4c077;
    --column-callouts-icon-color-2: #b87c69;
    --column-callouts-icon-color-3: #d2a087;

    position: relative;
    min-height: var(--column-callouts-min-height);
    display: grid;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
  }

  .column-callouts__backgrounds {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .column-callouts__background-image,
  .column-callouts__background-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .column-callouts__background-image--default {
    z-index: 0;
  }

  .column-callouts__background-image--hover {
    z-index: 1;
    opacity: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: opacity var(--column-callouts-hover-duration) var(--column-callouts-hover-easing);
  }

  @media (prefers-reduced-motion: reduce) {
    .column-callouts__background-image--hover {
      transition: none;
    }
  }

  .column-callouts__background-placeholder {
    background: rgb(var(--color-background-rgb));
  }

  .column-callouts__overlay {
    position: relative;
    z-index: 1;
    width: min(calc(100% - (2 * var(--page-margin))), var(--column-callouts-overlay-max-width));
    margin-inline: auto;
    margin-bottom: var(--page-margin);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: rgb(var(--color-background-rgb) / 0.7);
    backdrop-filter: blur(2px);
    border: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    border-radius: 24px;
  }

  .column-callouts__heading {
    margin: 0 0 var(--padding-md);
    text-align: center;
  }

  .column-callouts__grid {
    display: grid;
    grid-template-columns: repeat(var(--column-callouts-columns, 3), minmax(0, 1fr));
    gap: var(--gap-xl);
  }

  .column-callouts__item {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--padding-lg);
    padding-inline: clamp(1rem, 2vw, 1.75rem);
  }

  .column-callouts__item:focus {
    outline: none;
  }

  .column-callouts__item:focus-visible {
    outline: 2px solid rgb(var(--color-foreground-rgb));
    outline-offset: 4px;
    border-radius: 4px;
  }

  .column-callouts__item + .column-callouts__item {
    border-inline-start: 1px solid rgb(49 51 29 / 20%);
  }

  .column-callouts__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .column-callouts__icon :is(svg, img) {
    width: auto;
    height: 16px;
    max-width: 100%;
    object-fit: contain;
    display: block;
  }

  .column-callouts__item--icon-color-1 {
    --column-callouts-icon-hover-fill: var(--column-callouts-icon-color-1);
  }

  .column-callouts__item--icon-color-2 {
    --column-callouts-icon-hover-fill: var(--column-callouts-icon-color-2);
  }

  .column-callouts__item--icon-color-3 {
    --column-callouts-icon-hover-fill: var(--column-callouts-icon-color-3);
  }

  .column-callouts__icon svg,
  .column-callouts__icon svg :is(path, circle, rect, polygon, ellipse, line) {
    transition: fill var(--column-callouts-hover-duration) var(--column-callouts-hover-easing);
  }

  @media (hover: hover) {
    .column-callouts__item:hover .column-callouts__icon svg,
    .column-callouts__item:focus-within .column-callouts__icon svg,
    .column-callouts__item:hover .column-callouts__icon svg :is(path, circle, rect, polygon, ellipse, line),
    .column-callouts__item:focus-within .column-callouts__icon svg :is(path, circle, rect, polygon, ellipse, line) {
      fill: var(--column-callouts-icon-hover-fill) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .column-callouts__icon svg,
    .column-callouts__icon svg :is(path, circle, rect, polygon, ellipse, line) {
      transition: none;
    }
  }

  .column-callouts__item-heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--xl);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .column-callouts__item-text {
    margin: 0;
    margin-block-start: clamp(1rem, 2vw, 1.5rem);
    max-width: 28ch;
    transform: translateY(0);
    transition: transform var(--column-callouts-hover-duration) var(--column-callouts-hover-easing);
  }

  .column-callouts__item-text p {
    margin: 0;
  }

  @media (hover: hover) {
    .column-callouts__item:hover .column-callouts__item-text,
    .column-callouts__item:focus-within .column-callouts__item-text {
      transform: translateY(var(--column-callouts-text-lift));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .column-callouts__item-text {
      transition: none;
    }
  }

  @media screen and (max-width: 749px) {
    .column-callouts {
      min-height: auto;
    }

    .column-callouts__overlay {
      width: min(calc(100% - (2 * var(--page-margin))), 42rem);
      margin-bottom: var(--padding-lg);
      margin-top: var(--padding-lg);
      padding: var(--padding-lg);
      border-radius: 20px;
    }

    .column-callouts__grid {
      grid-template-columns: 1fr;
      gap: var(--padding-lg);
    }

    .column-callouts__item {
      padding-inline: 0;
    }

    .column-callouts__item + .column-callouts__item {
      border-inline-start: 0;
      border-top: 1px solid rgb(49 51 29 / 20%);
      padding-top: var(--padding-lg);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Column callouts",
  "tag": "section",
  "class": "section-column-callouts",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Shown by default. Each column can show a different image on hover."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 640,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 980
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "500px", "label": "Small" },
        { "value": "620px", "label": "Medium" },
        { "value": "740px", "label": "Large" }
      ],
      "default": "620px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Callout",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Hover background image"
        },
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (SVG or HTML)",
          "info": "Paste an SVG or other HTML markup. Decorative icons should use aria-hidden on the SVG element."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Callout heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add supporting callout text here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Column callouts",
      "blocks": [
        {
          "type": "callout",
          "settings": {
            "title": "Natural",
            "text": "<p>We are committed to sourcing the most exceptional natural ingredients.</p>"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "Artisanal",
            "text": "<p>Our perfumers blend essence by hand to create complex fragrances.</p>"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "Sustainable",
            "text": "<p>From sourcing to packaging, every step favors environmental stewardship.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
