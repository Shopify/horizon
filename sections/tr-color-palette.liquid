{% liquid
  assign color_filter = nil
  assign filter_option = section.settings.filter_option | downcase

  for filter in collection.filters
    assign filter_label_down = filter.label | downcase
    if filter_label_down == filter_option
      assign color_filter = filter
      break
    endif
  endfor

  assign has_swatch = false
  if color_filter != blank
    assign swatch_index = color_filter.values | find_index: 'swatch'
    if swatch_index != null
      assign has_swatch = true
    endif
  endif
%}

{% if color_filter != blank and color_filter.values.size > 0 %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
    style="{% render 'spacing-padding', settings: section.settings %}"
  >
    <div class="color-grid">
      {% if section.settings.heading != blank %}
        <p class="color-grid__heading" style="font-size: {{ section.settings.heading_font_size }}px;">
          {{ section.settings.heading }}
        </p>
      {% endif %}

      <div
        class="color-grid__swatches"
        style="--swatch-size: {{ section.settings.swatch_size }}px; --swatch-gap: {{ section.settings.swatch_gap }}px;"
      >
        {%- comment -%} Show All button {%- endcomment -%}
        <button
          type="button"
          class="color-grid__swatch-btn color-grid__show-all {% unless color_filter.active_values.size > 0 %}color-grid__swatch-btn--active{% endunless %}"
          data-color-grid-clear
          aria-label="{{ section.settings.show_all_label }}"
        >
          <span class="color-grid__show-all-circle" style="width: {{ section.settings.swatch_size }}px; height: {{ section.settings.swatch_size }}px;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="60%" height="60%">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </span>
          {% if section.settings.show_labels %}
            <span class="color-grid__label">{{ section.settings.show_all_label }}</span>
          {% endif %}
        </button>

        {%- for value in color_filter.values -%}
          {%- if value.count > 0 or value.active -%}
            <button
              type="button"
              class="color-grid__swatch-btn {% if value.active %}color-grid__swatch-btn--active{% endif %}"
              data-color-grid-filter
              data-param-name="{{ value.param_name }}"
              data-param-value="{{ value.value }}"
              aria-label="{{ value.label }}"
              aria-pressed="{{ value.active }}"
            >
              <span class="color-grid__swatch-wrapper" style="width: {{ section.settings.swatch_size }}px; height: {{ section.settings.swatch_size }}px;">
                {% if has_swatch %}
                  {% render 'swatch', swatch: value.swatch, mode: 'filter' %}
                {% else %}
                  <span class="color-grid__color-fallback">{{ value.label | truncate: 2, '' }}</span>
                {% endif %}
              </span>
              {% if section.settings.show_labels %}
                <span class="color-grid__label">{{ value.label }}</span>
              {% endif %}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .color-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .color-grid__heading {
    margin: 0;
    font-weight: 600;
  }

  .color-grid__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: var(--swatch-gap, 10px);
    align-items: flex-start;
  }

  .color-grid__swatch-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    transition: opacity 0.15s ease;
    position: relative;
    width: calc(var(--swatch-size, 36px) + 24px);
  }

  .color-grid__swatch-btn:hover {
    opacity: 0.8;
  }

  .color-grid__swatch-wrapper {
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    box-sizing: content-box;
  }

  .color-grid__swatch-wrapper .swatch {
    width: 100% !important;
    height: 100% !important;
    border-radius: 50%;
  }

  .color-grid__swatch-btn--active .color-grid__swatch-wrapper {
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-foreground);
  }

  .color-grid__show-all-circle {
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-border, rgba(0, 0, 0, 0.12));
    box-sizing: content-box;
    color: var(--color-foreground);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .color-grid__show-all.color-grid__swatch-btn--active .color-grid__show-all-circle {
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-foreground);
  }

  .color-grid__label {
    font-size: 0.75rem;
    color: var(--color-foreground);
    width: 100%;
    text-align: center;
    word-wrap: break-word;
    overflow-wrap: break-word;
    line-height: 1.3;
  }

  .color-grid__color-fallback {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border, #ccc);
    font-size: 0.625rem;
    text-transform: uppercase;
    color: var(--color-foreground);
  }
{% endstylesheet %}

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]') || document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    function getFacetsForm() {
      return document.querySelector('facets-form-component');
    }

    function buildFilterURL(paramName, paramValue, toggle) {
      const url = new URL(window.location.href);
      // Remove page param
      url.searchParams.delete('page');

      if (toggle) {
        // If already active, remove it; otherwise add it
        const existing = url.searchParams.getAll(paramName);
        if (existing.includes(paramValue)) {
          // Remove this specific value
          url.searchParams.delete(paramName);
          existing.filter(v => v !== paramValue).forEach(v => url.searchParams.append(paramName, v));
        } else {
          url.searchParams.append(paramName, paramValue);
        }
      }

      return url.toString();
    }

    function clearColorFilter() {
      const url = new URL(window.location.href);
      url.searchParams.delete('page');
      // Remove all params matching our filter option
      const paramName = '{{ color_filter.values[0].param_name | default: "" }}';
      if (paramName) {
        url.searchParams.delete(paramName);
      }
      return url.toString();
    }

    // Color swatch click handlers
    section.querySelectorAll('[data-color-grid-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        const paramName = btn.getAttribute('data-param-name');
        const paramValue = btn.getAttribute('data-param-value');
        const newURL = buildFilterURL(paramName, paramValue, true);
        const facetsForm = getFacetsForm();
        if (facetsForm) {
          facetsForm.updateFiltersByURL(newURL);
        } else {
          window.location.href = newURL;
        }
      });
    });

    // Show All click handler
    section.querySelectorAll('[data-color-grid-clear]').forEach(btn => {
      btn.addEventListener('click', () => {
        const newURL = clearColorFilter();
        const facetsForm = getFacetsForm();
        if (facetsForm) {
          facetsForm.updateFiltersByURL(newURL);
        } else {
          window.location.href = newURL;
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "TR Color palette",
  "templates": ["collection"],
  "settings": [
    {
      "type": "header",
      "content": "Filter"
    },
    {
      "type": "text",
      "id": "filter_option",
      "label": "Filter option name",
      "info": "Enter the filter label exactly as it appears in your Shopify filters (e.g., Color, Colour, Material).",
      "default": "Color"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Filter by color"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "text",
      "id": "show_all_label",
      "label": "Show all label",
      "default": "All"
    },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "Show color labels",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "swatch_size",
      "label": "Swatch size",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "swatch_gap",
      "label": "Swatch spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "TR Color palette"
    }
  ]
}
{% endschema %}
