{%- doc -%}
  Renders featured mega menu layout with left links and right featured cards.

  Featured cards come from the parent menu link's page metafields:
  `custom.megamenu_featured_collections` (list of collections).
  `custom.megamenu_featured_pages` (list of pages, optional image at `page.metafields.custom.megamenu_image`).

  @param {object} parent_link - Top-level navigation link with submenu children
  @param {object} block_settings - Header menu block settings (CTA, aspect ratio)
  @param {number} [image_border_radius] - Border radius for card images
  @param {object} [section] - Section object used for image loading behavior
{%- enddoc -%}

{% liquid
  assign cta_label = block_settings.featured_collections_cta_label
  assign cta_link = block_settings.featured_collections_cta_link
  assign card_aspect_ratio = '4 / 5'

  assign parent_page = blank
  if parent_link.type == 'page_link' and parent_link.object != blank
    assign parent_page = parent_link.object
  elsif parent_link.url contains '/pages/'
    assign page_handle = parent_link.url | split: '/pages/' | last | split: '?' | first | split: '#' | first
    assign parent_page = pages[page_handle]
  endif

  assign megamenu_featured_collections = blank
  assign megamenu_featured_pages = blank
  if parent_page != blank
    assign megamenu_featured_collections = parent_page.metafields.custom.megamenu_featured_collections.value
    assign megamenu_featured_pages = parent_page.metafields.custom.megamenu_featured_pages.value
  endif
%}

{%- capture image_sizes -%}
  {%- render 'util-mega-menu-img-sizes-attr',
    menu_content_type: 'featured_collections',
    settings: section.settings
  -%}
{%- endcapture -%}

<div class="mega-menu-featured-collections">
  <div class="mega-menu-featured-collections__links">
    <h5 class="mega-menu-featured-collections__heading">
      {{ parent_link.title | escape }}
    </h5>
    <ul class="mega-menu-featured-collections__links-list list-unstyled">
      {% for link in parent_link.links %}
        <li class="mega-menu-featured-collections__links-item">
          <a href="{{ link.url }}" class="mega-menu-featured-collections__link">
            <span class="mega-menu__link-icon mega-menu-featured-collections__link-icon svg-wrapper" aria-hidden="true">
              {{- 'icon-megamenu-link-arrow.svg' | inline_asset_content -}}
            </span>
            <span class="wrap-text">{{ link.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
    {% if cta_label != blank and cta_link != blank %}
      <a href="{{ cta_link }}" class="button mega-menu-featured-collections__cta">
        <span class="button__label">{{ cta_label | escape }}</span>
      </a>
    {% endif %}
  </div>

  <ul
    class="mega-menu-featured-collections__cards list-unstyled"
    style="--resource-card-corner-radius: {{ image_border_radius }}px; --mega-featured-card-aspect-ratio: {{ card_aspect_ratio }};"
  >
    {% assign featured_cards_count = 0 %}
    {%- if megamenu_featured_collections != blank -%}
      {%- for collection in megamenu_featured_collections -%}
        {%- if collection != blank -%}
          <li class="mega-menu-featured-collections__card">
            {% render 'resource-card',
              resource: collection,
              resource_type: 'collection',
              collection_thumbnails: 'single',
              image_aspect_ratio: card_aspect_ratio,
              image_sizes: image_sizes,
              image_loading: 'eager'
            %}
          </li>
          {% assign featured_cards_count = featured_cards_count | plus: 1 %}
          {% if featured_cards_count >= 3 %}
            {% break %}
          {% endif %}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if featured_cards_count < 3 and megamenu_featured_pages != blank -%}
      {%- for featured_page in megamenu_featured_pages -%}
        {%- if featured_page != blank -%}
          <li class="mega-menu-featured-collections__card">
            {% render 'resource-card',
              resource: featured_page,
              resource_type: 'page',
              resource_image: featured_page.metafields.custom.megamenu_image.value,
              image_aspect_ratio: card_aspect_ratio,
              image_sizes: image_sizes,
              image_loading: 'eager'
            %}
          </li>
          {% assign featured_cards_count = featured_cards_count | plus: 1 %}
          {% if featured_cards_count >= 3 %}
            {% break %}
          {% endif %}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </ul>
</div>
