{%- doc -%}
  Vertical social share buttons for blog article pages.

  @param {article} article - The blog article to share
{%- enddoc -%}

{%- liquid
  assign share_url = request.origin | append: article.url
  assign share_title = article.title | url_param_escape
  assign share_url_encoded = share_url | url_param_escape

  assign facebook_url = 'https://www.facebook.com/sharer/sharer.php?u=' | append: share_url_encoded
  assign linkedin_url = 'https://www.linkedin.com/sharing/share-offsite/?url=' | append: share_url_encoded
  assign x_url = 'https://twitter.com/intent/tweet?url=' | append: share_url_encoded | append: '&text=' | append: share_title
  assign email_url = 'mailto:?subject=' | append: share_title | append: '&body=' | append: share_url_encoded
-%}

<aside class="blog-article-share" aria-label="{{ 'blogs.article.share' | t }}">
  <ul class="blog-article-share__list list-unstyled" role="list">
    <li class="blog-article-share__item">
      <a
        class="blog-article-share__button"
        href="{{ facebook_url }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="visually-hidden">{{ 'blogs.article.share_on_facebook' | t }}</span>
        <svg class="blog-article-share__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          {%- render 'icon', icon: 'facebook' -%}
        </svg>
      </a>
    </li>
    <li class="blog-article-share__item">
      <a
        class="blog-article-share__button"
        href="{{ linkedin_url }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="visually-hidden">{{ 'blogs.article.share_on_linkedin' | t }}</span>
        <svg class="blog-article-share__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          {%- render 'icon', icon: 'linkedin' -%}
        </svg>
      </a>
    </li>
    <li class="blog-article-share__item">
      <a
        class="blog-article-share__button"
        href="{{ x_url }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="visually-hidden">{{ 'blogs.article.share_on_x' | t }}</span>
        <svg class="blog-article-share__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          {%- render 'icon', icon: 'x' -%}
        </svg>
      </a>
    </li>
    <li class="blog-article-share__item">
      <button
        type="button"
        class="blog-article-share__button blog-article-share__button--copy"
        data-share-copy-url="{{ share_url | escape }}"
        data-share-copied-label="{{ 'blogs.article.link_copied' | t }}"
      >
        <span class="visually-hidden">{{ 'blogs.article.share_on_tiktok' | t }}</span>
        <svg class="blog-article-share__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          {%- render 'icon', icon: 'tiktok' -%}
        </svg>
      </button>
    </li>
    <li class="blog-article-share__item">
      <a class="blog-article-share__button" href="{{ email_url }}">
        <span class="visually-hidden">{{ 'blogs.article.share_by_email' | t }}</span>
        <svg class="blog-article-share__icon" aria-hidden="true" focusable="false" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M2.5 4.75C2.5 4.05964 3.05964 3.5 3.75 3.5H16.25C16.9404 3.5 17.5 4.05964 17.5 4.75V15.25C17.5 15.9404 16.9404 16.5 16.25 16.5H3.75C3.05964 16.5 2.5 15.9404 2.5 15.25V4.75ZM4.07324 5L10 9.64645L15.9268 5H4.07324ZM3.5 5.40257V14.75C3.5 14.8881 3.61193 15 3.75 15H16.25C16.3881 15 16.5 14.8881 16.5 14.75V5.40257L10.3326 10.2239C10.1348 10.3847 9.86521 10.3847 9.66739 10.2239L3.5 5.40257Z"
            fill="currentColor"
            fill-rule="evenodd"
            clip-rule="evenodd"
          />
        </svg>
      </a>
    </li>
  </ul>
</aside>

<script type="module">
  document.querySelectorAll('.blog-article-share').forEach((share) => {
    share.querySelectorAll('.blog-article-share__button--copy').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-share-copy-url');
        const copiedLabel = button.getAttribute('data-share-copied-label') || 'Link copied';

        if (!url) return;

        try {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(url);
          } else {
            window.prompt('Copy this link:', url);
            return;
          }

          button.classList.add('blog-article-share__button--copied');
          button.setAttribute('aria-label', copiedLabel);

          window.setTimeout(() => {
            button.classList.remove('blog-article-share__button--copied');
            button.removeAttribute('aria-label');
          }, 2000);
        } catch {
          window.prompt('Copy this link:', url);
        }
      });
    });
  });
</script>

{% stylesheet %}
  .blog-article-share {
    width: 100%;
    max-width: var(--normal-content-width);
    margin-block-start: var(--gap-2xl);
    margin-inline: auto;
    padding-block-start: var(--gap-xl);
  }

  .blog-article-share__list {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--gap-sm);
    margin: 0;
    padding: 0;
  }

  .blog-article-share__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 4px;
    border: none;
    border-radius: 100%;
    background-color: #f9d8af;
    color: #31331d;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .blog-article-share__button:hover {
    transform: scale(1.05);
    background-color: #f4c077;
  }

  .blog-article-share__button:focus-visible {
    outline: 2px solid #31331d;
    outline-offset: 2px;
  }

  .blog-article-share__button--copied {
    background-color: #d2a087;
  }

  .blog-article-share__icon {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .blog-article-share__icon path {
    fill: currentColor;
  }

  @media screen and (min-width: 990px) {
    .blog-article-share {
      width: auto;
      max-width: none;
      margin-block-start: 0;
      margin-inline: 0;
      padding-block-start: var(--padding-4xl);
      position: sticky;
      top: calc(var(--header-height, 0px) + var(--gap-xl));
      align-self: start;
    }

    .blog-article-share__list {
      flex-direction: column;
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-article-share__button {
      transition: none;
    }

    .blog-article-share__button:hover {
      transform: none;
    }
  }
{% endstylesheet %}
