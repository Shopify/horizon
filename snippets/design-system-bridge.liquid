{% comment %}
  Overrides Horizon's final type variables with Mionas design-system tokens from
  assets/design-tokens.css.

  Rendered AFTER theme-styles-variables so these declarations win the cascade.

  Only size, line-height and letter-spacing are bridged: they are the only three values
  Shopify settings cannot express (the size enum has no 38/28/22, line-heights are ratios,
  and tracking is capped at +/-0.03em where the brand needs 0.02em). Family, weight and case
  come from the theme's font settings so Shopify keeps hosting and preloading the faces.

  Token names are mirrored in scripts/design-tokens-contract.mjs, which fails the sync if any
  of them stop existing.
{% endcomment %}
{% style %}
  :root {
    /* h1 -> hero. Fixed, not clamped. It previously spent display-lg (48px), which sat exactly at
       Horizon's 48px fluid cutoff and so kept a clamp() with a derived 2.75rem (44px) floor. The
       design system has since collapsed the display family into `hero` at 38px, which is BELOW the
       cutoff -- so h1 now follows the same rule as h2..h6 and takes the token directly.
       Keeping the clamp would have been silently broken: clamp(44px, 4.8vw, 38px) has a minimum
       above its maximum, and CSS resolves that to the minimum, pinning h1 at a fixed 44px --
       larger than the token it is supposed to cap at, with no error anywhere. */
    --font-h1--size: var(--text-role-hero-font-size);
    --font-h1--line-height: var(--text-role-hero-line-height);
    --font-h1--letter-spacing: var(--text-role-hero-letter-spacing);

    /* h2 -> title. Below the fluid cutoff, so fixed. */
    --font-h2--size: var(--text-role-title-font-size);
    --font-h2--line-height: var(--text-role-title-line-height);
    --font-h2--letter-spacing: var(--text-role-title-letter-spacing);

    /* h3 -> title. Same role as h2: the collapsed scale has one 28px step. */
    --font-h3--size: var(--text-role-title-font-size);
    --font-h3--line-height: var(--text-role-title-line-height);
    --font-h3--letter-spacing: var(--text-role-title-letter-spacing);

    /* h4 -> heading */
    --font-h4--size: var(--text-role-heading-font-size);
    --font-h4--line-height: var(--text-role-heading-line-height);
    --font-h4--letter-spacing: var(--text-role-heading-letter-spacing);

    /* h5 -> subheading */
    --font-h5--size: var(--text-role-subheading-font-size);
    --font-h5--line-height: var(--text-role-subheading-line-height);
    --font-h5--letter-spacing: var(--text-role-subheading-letter-spacing);

    /* h6 -> subheading. Intentionally identical to h5: the target design has no sixth heading
       level, and keeping h6 a true heading beats demoting it to a label. */
    --font-h6--size: var(--text-role-subheading-font-size);
    --font-h6--line-height: var(--text-role-subheading-line-height);
    --font-h6--letter-spacing: var(--text-role-subheading-letter-spacing);

    /* paragraph -> body */
    --font-paragraph--size: var(--text-role-body-font-size);
    --font-paragraph--line-height: var(--text-role-body-line-height);
    --font-paragraph--letter-spacing: var(--text-role-body-letter-spacing);

    /* Buttons — Horizon states no height: it derives one from padding-block plus the paragraph
       line-height (base.css:1255). The design system states height directly (48px) with 24px
       inline padding. Derive the padding-block that yields the design system's height at the
       line-height this bridge already set: (48px - 24px) / 2 = 12px. */
    --button-padding-block: calc(
      (var(--button-size-md-height) - var(--text-role-body-line-height)) / 2
    );
    --button-padding-inline: var(--button-size-md-padding);
  }

  /* Horizon gives button labels the paragraph weight (400, base.css:1245); the design system's
     buttons are semibold. No Shopify setting exposes button weight, so this needs a rule.
     Same selector list as base.css:1229-1232, and this snippet renders after base.css, so it
     wins on source order at equal specificity.
     .button-unstyled is excluded: it strips padding/background/border to read as plain text
     (base.css:1361), and must not be bolded. base.css uses this same :not() idiom at line 1265. */
  .button:not(.button-unstyled),
  .button-secondary,
  .button-custom,
  button.shopify-payment-button__button--unbranded {
    font-weight: var(--font-weight-semibold);
  }

  /* Footer tagline — a merchant-added `text` block inside the footer group, set to
     type_preset "custom" with font "Accent" (Oswald), reads as the design system's tagline line
     (e.g. "Bakery & specialty coffee · Sitges"). `text.liquid`/`typography-style.liquid` always
     emit `--font-family: var(--font-accent--family);` inline plus a `custom-typography` class for
     that combination, so this targets it directly rather than adding a dedicated Horizon block
     type. Scoped to the real `<footer>` element `theme.liquid` wraps the footer-group render in,
     so it can't affect accent-font custom text elsewhere on the page. */
  footer .custom-typography[style*='--font-family: var(--font-accent--family)'] {
    color: var(--footer-tagline-foreground);
  }
{% endstyle %}
