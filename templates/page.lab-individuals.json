        "ingredient_3fX33P": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 1: SCENT DISCOVERY",
            "description": "<p>Through a personal discovery session, we explore your memories, emotions, and individuality, uncovering the essence of who you are and how you want to be experienced.</p>",
