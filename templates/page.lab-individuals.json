        "ingredient_tcinaa": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 2: FROM MEMORY TO INSPIRATION",
            "description": "<p>We curate a palette of natural notes that reflect your story. Translating moments, places, and feelings into a unique olfactory direction that is entirely your own.<br/></p>",
            "image": "shopify://shop_images/47118989-ddc4-4992-9325-c86df7889e42-removebg-preview.png"
          }
        },
        "ingredient_GKmiYC": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 3: ARTISANAL CREATION",
            "description": "<p>Our in-house perfumer and scent scientists carefully blend 100% natural botanicals to craft a fragrance that is deeply personal and uniquely yours. Each composition is created with precision, artistry, and an unwavering commitment to authenticity.</p>",
            "image": "shopify://shop_images/7c50cdcb-3f0e-48e8-8b0a-732c090b03ed.png"
          }
        },
        "ingredient_JyhUz7": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 4: REFINEMENT & EVOLUTION",
            "description": "<p>We refine your fragrance together, ensuring it resonates perfectly with your senses. Evolving until it feels instinctively right, like a true extension of you.</p>",
            "image": "shopify://shop_images/3636cfd5-8dc7-4a9d-9e3b-3ffc699f102f-removebg-preview.png"
          }
        },
        "ingredient_JtzFgk": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 5: YOUR SIGNATURE SCENT",
            "description": "<p>Your bespoke fragrance becomes your personal signature. Distinctive, memorable, and impossible to replicate. A scent that lingers, tells your story, and leaves a lasting impression.</p>",
            "image": "shopify://shop_images/2220b059-86a3-47e7-9c87-369b620f2818-removebg-preview.png"
          }
        },
        "ingredient_Q3LJV3": {
          "type": "ingredient",
          "settings": {
            "title": "STEP 6: CONTINUITY & RE-CREATION",
            "description": "<p>Your formula is saved on our archives and can be recreated or evolved over time, allowing your scent to grow with you. Whether as a personal fragrance or across candles, home scents, and more.</p>",
            "image": "shopify://shop_images/040eb0ed-7b6f-4712-a876-bada12819f6d-removebg-preview.png"
          }
        }
