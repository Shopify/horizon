            "text_MaFgHD": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<p>Cala Falcó is a family owned 42.5 hectare estate on the dramatic coastline of Mallorca.  </p>",
                "width": "fit-content",
