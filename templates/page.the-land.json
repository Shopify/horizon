              "name": "t:names.heading",
              "settings": {
                "text": "<p>An Invitation to The Cala Falcó Way</p>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h2",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
