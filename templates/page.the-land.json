    "ingredients_m643zQ": {
      "type": "ingredients",
      "blocks": {
        "ingredient_hXMqRY": {
          "type": "ingredient",
          "settings": {
            "title": "Montserrat Valle",
            "description": "<p><em>Founder</em></p><p></p><p>Montserrat Valle is the the founder whose deep intuition, curiosity, and love for the land gave birth to the project. With a unique ability to see potential where others see rawness, she weaves together agriculture, science, art, and social purpose into a living ecosystem.</p>",
            "image": "shopify://shop_images/Hand_in_Soil.jpg"
          }
        },
        "ingredient_eLqFRE": {
          "type": "ingredient",
          "settings": {
            "title": "esteve gomila",
            "description": "<p><em>Botanist & Microbiologist</em><br/><br/>Esteve Gomila, is the alchemist behind each of our botanical beverages. With a rare ability to translate ideas into tangible creations, he takes inspiration from the land, the plants, and their stories to formulate prototypes that awaken the senses.</p>",
            "image": "shopify://shop_images/Esteve_Gomila.jpg"
          }
        },
        "ingredient_QJPYBT": {
          "type": "ingredient",
          "settings": {
            "title": "tatsiana salamanca",
            "description": "<p><em>Lab Manager</em></p><p></p><p>With a PhD in Chemistry and nearly a decade of experience in advanced materials research, Tatsiana brings scientific precision and methodical rigor to Cala Falcó’s laboratory. She oversees the meticulous production of each formula, ensuring<br/>consistency, quality, and fidelity to the original vision.</p>",
            "image": "shopify://shop_images/Tatsiana_Salamanca.jpg"
          }
        },
        "ingredient_3m4EpM": {
          "type": "ingredient",
          "settings": {
            "title": "VICTOR ALARCÓN",
            "description": "<p><em>Biochemist, Lab Director & Co-Founder</em><br/><br/>Víctor Alarcón leads the lab with precision and passion, ensuring that every process—from distillation to production—meets the highest standards. He translates ideas from the field into real, tangible products, bridging creativity and execution. </p>",
            "image": "shopify://shop_images/V_ctor_Alarc_n.jpg"
          }
        },
        "ingredient_CrGUH6": {
          "type": "ingredient",
          "settings": {
            "title": "maria sánchez",
            "description": "<p>Lorem ipsum<br/><br/>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>",
            "image": "shopify://shop_images/68861fa431a371dd91d95772_ROSEMARY_ILLUSTRATION.png"
          }
        }
      },
